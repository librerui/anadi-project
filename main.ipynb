    "import unicodedata\n",
    "\n",
    "def normalizar(s):\n",
    "    if pd.isna(s): return \"\"\n",
    "    s = str(s).strip().lower()\n",
    "    s = unicodedata.normalize('NFKD', s)\n",
    "    s = ''.join(c for c in s if not unicodedata.combining(c))\n",
    "    return s\n",
    "\n",
    "# Preparar os dados de Omissão (PTDs) antes do merge\n",
    "# Importante: calculamos a percentagem de NaNs por concelho aqui\n",
    "total_por_concelho = ptd_data.groupby('Concelho').agg(\n",
    "    Pct_Indet=('Nível de Utilização [%]', lambda x: (\n",
    "        (x.isna().sum() + (x < 0.20).sum()) / len(x)\n",
    "    ) * 100)\n",
    ").reset_index();\n",
    "\n",
    "# Processamento da Densidade\n",
    "pop_raw = pd.read_csv(\"./data/densidade.csv\", sep=';', encoding='latin1', skiprows=2)\n",
    "col_nuts = pop_raw.columns[1]\n",
    "col_dens = pop_raw.columns[2]\n",
    "\n",
    "# Filtra apenas concelhos\n",
    "pop_concelhos = pop_raw[pop_raw[col_nuts].str.contains(r'^\\d{7}:', na=False)].copy()\n",
    "pop_concelhos['Nome_norm'] = pop_concelhos[col_nuts].str.split(':').str[1].apply(normalizar)\n",
    "pop_concelhos['Densidade'] = pd.to_numeric(\n",
    "    pop_concelhos[col_dens].astype(str).str.replace(',', '.').str.replace(r'\\s+', '', regex=True), \n",
    "    errors='coerce'\n",
    ")\n",
    "\n",
    "# Merge usando os nomes normalizados\n",
    "total_por_concelho['Nome_norm'] = total_por_concelho['Concelho'].apply(normalizar)\n",
    "df_final = total_por_concelho.merge(pop_concelhos[['Nome_norm', 'Densidade']], on='Nome_norm', how='inner')\n",
    "\n",
    "# Classificação e Gráfico\n",
    "threshold = df_final['Pct_Indet'].median()\n",
    "df_final['Tipo_Dados'] = np.where(df_final['Pct_Indet'] > threshold, 'Alta Omissão', 'Dados Robustos')\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.regplot(\n",
    "    data=df_final, \n",
    "    x='Densidade', \n",
    "    y='Pct_Indet', \n",
    "    scatter_kws={'alpha':0.5, 'color':'teal'}, \n",
    "    line_kws={'color':'red', 'label':'Tendência'}\n",
    ")\n",
    "\n",
    "plt.xscale('log')\n",
    "plt.title('Correlação: Densidade Populacional vs. % de Dados Omissos', fontsize=14)\n",
    "plt.xlabel('Densidade Populacional (Hab/km² - Escala Log)')\n",
    "plt.ylabel('% de Dados Omissos (NaN)')\n",
    "plt.grid(True, which=\"both\", ls=\"--\", alpha=0.5)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(df_final.groupby('Tipo_Dados')['Densidade'].describe()[['mean', '50%', 'min', 'max']])"
   ]
